{
	"compilerOptions": {
		"target": "ES2020",
		"module": "nodenext", // or "nodenext"
		"moduleResolution": "nodenext", // or "nodenext"
		"outDir": "./server",
		"declaration": true,
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true
	},
	"include": ["**/*.ts"],
	"exclude": ["node_modules"]
}
